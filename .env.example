# Supabase - REST API (funciona aunque Postgres directo esté bloqueado)
# Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # service_role key (secret)

# Storage: bucket público para fotos subidas por clubes (opcional, default club-photos)
# Ver docs/supabase-storage-club-photos.md
# SUPABASE_STORAGE_BUCKET=club-photos

# Postgres directo (para Prisma, migraciones)
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Auth.js - generar con: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# NextAuth URL (para callbacks)
NEXTAUTH_URL="http://localhost:3000"
