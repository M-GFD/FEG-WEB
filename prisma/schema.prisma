// FEG Platform - Prisma schema for Supabase/PostgreSQL
// Compatible with Supabase: use connection string from Supabase dashboard

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ AUTH & USERS ============
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String    // Hash bcrypt (solo Credentials, sin OAuth)
  mustChangePassword Boolean  @default(false)
  emailVerified     DateTime?
  name              String?
  image             String?
  role              Role      @default(PUBLIC)
  clubId            String?
  club              Club?     @relation(fields: [clubId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  PUBLIC
  CLUB
  PRESS
  DIRECTOR
  TREASURER
  ADMIN
}

/// Destino editorial: general (todo el sitio), menores o mayores.
enum ContentAudience {
  GENERAL
  MENORES
  MAYORES
}

// ============ CORE ENTITIES ============
model Club {
  id        String   @id @default(cuid())
  code      String?  @unique // Código AAG/FEG (ej. "302" Estudiantes Paraná)
  name      String
  slug      String   @unique
  logoUrl   String?
  address   String?
  phone     String?
  users     User[]
  players   Player[]
  tournaments Tournament[]
  expenses  Expense[]
  teamEntries TeamEntry[]
  youthEnrollments YouthEnrollment[]
  youthTournamentRegistrations YouthTournamentRegistration[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Player {
  id             String          @id @default(cuid())
  matricula      String?         // Nº de matrícula AAG/FEG
  firstName      String
  lastName       String
  handicap       Int             @default(0) // Compat: entero; sincronizado con índice al publicar rondas
  handicapIndex  Float?          // WHS Handicap Index (padrón y/o recalculado desde torneos publicados)
  handicapCourse Float?          // Handicap cancha
  califIda       Float?
  slopeIda       Int?
  califVta       Float?
  slopeVta       Int?
  califTotal     Float?
  slopeTotal     Int?
  category       String?         // CAB, DAM, CAB-24, DAM75%, etc.
  birthYear      Int             @default(1900)  // 1900 = desconocido
  birthDate      DateTime?       @db.Date
  age            Int?
  gender         Gender
  clubId         String
  club           Club            @relation(fields: [clubId], references: [id])

  // Datos sensibles cifrados (AES-256-GCM). NO se exponen al frontend.
  emailEnc       String?
  phoneEnc       String?
  dniEnc         String?
  /// SHA-256 de DNI canonico; misma formula que YouthEnrollment.dniHash
  dniHash        String?

  entries        TournamentEntry[]
  teamEntries    TeamPlayer[]
  rankingEntries RankingEntry[]
  publishedHandicapRounds PublishedHandicapRound[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([firstName, lastName, clubId])
  @@unique([clubId, matricula], name: "Player_clubId_matricula_key")
  @@index([lastName])
  @@index([firstName])
  @@index([dniHash])
}

enum Gender {
  M
  F
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  date        DateTime
  clubId      String
  club        Club     @relation(fields: [clubId], references: [id])
  /// WHS: Slope Rating del tee jugado (opcional).
  whsSlopeRating   Int?
  /// WHS: Course Rating del tee jugado (opcional).
  whsCourseRating  Float?
  /// WHS: Par del recorrido 18 hoyos (opcional).
  whsPar           Int?
  isTeamEvent Boolean  @default(false)
  multiplier  Float    @default(1)
  audience    ContentAudience @default(GENERAL)
  status      TournamentStatus @default(DRAFT)
  entries     TournamentEntry[]
  teamEntries TeamEntry[]
  publishedHandicapRounds PublishedHandicapRound[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Tarjeta 18 hoyos **publicada**: diferencial WHS para recalcular Handicap Index (no se escribe hasta publicar).
model PublishedHandicapRound {
  id                  String     @id @default(cuid())
  playerId            String
  player              Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournamentId        String
  tournament          Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentEntryId   String     @unique
  playedAt            DateTime   @db.Date
  gross               Int
  adjustedGross       Int
  differential        Float
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([playerId, playedAt(sort: Desc)])
}

enum TournamentStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  PUBLISHED
  CLOSED
}

model TournamentEntry {
  id           String       @id @default(cuid())
  tournamentId String
  tournament   Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerId     String
  player       Player       @relation(fields: [playerId], references: [id])
  category     Category
  scorecard    Scorecard?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([tournamentId, playerId])
}

enum Category {
  DAMAS_SCRATCH
  DAMAS_HASTA_30
  DAMAS_31_59
  SENIOR_DAMAS_50
  CABALLEROS_SCRATCH
  CABALLEROS_HASTA_9
  CABALLEROS_10_16
  CABALLEROS_17_24
  CABALLEROS_25_54
  SENIOR_CABALLEROS_55
}

model Scorecard {
  id             String         @id @default(cuid())
  entryId        String         @unique
  entry          TournamentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  status         ScorecardStatus @default(PENDING)
  h1             Int?
  h2             Int?
  h3             Int?
  h4             Int?
  h5             Int?
  h6             Int?
  h7             Int?
  h8             Int?
  h9             Int?
  h10            Int?
  h11            Int?
  h12            Int?
  h13            Int?
  h14            Int?
  h15            Int?
  h16            Int?
  h17            Int?
  h18            Int?
  gross          Int?
  net            Int?
  position       Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum ScorecardStatus {
  PENDING
  DRAFT
  COMPLETE
  PUBLISHED
  DISQUALIFIED
}

// ============ TEAM EVENTS ============
model TeamEntry {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  clubId       String
  club         Club       @relation(fields: [clubId], references: [id])
  players      TeamPlayer[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tournamentId, clubId])
}

model TeamPlayer {
  id          String     @id @default(cuid())
  teamEntryId String
  teamEntry   TeamEntry  @relation(fields: [teamEntryId], references: [id], onDelete: Cascade)
  playerId    String
  player      Player     @relation(fields: [playerId], references: [id])
  order       Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([teamEntryId, playerId])
}

// ============ PRESS / MEDIA ============
model Photo {
  id        String      @id @default(cuid())
  url       String
  caption   String?
  status    PhotoStatus @default(PENDING)
  featured  Boolean     @default(false)
  uploadedBy String
  approvedBy String?
  tournamentId String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    // HTML (TipTap / prensa)
  excerpt     String?
  imageUrl    String?   // Portada (listados y cabecera)
  galleryUrls Json?     // string[] URLs imágenes adicionales (galería al pie)
  published   Boolean   @default(false)
  publishedAt DateTime?
  audience    ContentAudience @default(GENERAL)
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  translations NewsTranslation[]
}

/// Traducciones persistidas (en/pt). El español canónico vive en News.
model NewsTranslation {
  id        String   @id @default(cuid())
  newsId    String
  news      News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  locale    String   // "en" | "pt"
  title     String
  excerpt   String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([newsId, locale])
  @@index([newsId])
  @@index([locale])
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Videos explicativos publicados en Reglamento (admin).
model ReglamentoVideo {
  id        String   @id @default(cuid())
  title     String
  body      String
  videoUrl  String
  mimeType  String
  published Boolean  @default(true)
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ TREASURY ============
model Expense {
  id          String        @id @default(cuid())
  clubId      String
  club        Club          @relation(fields: [clubId], references: [id])
  amount      Float
  description String
  receiptUrl  String?
  status      ExpenseStatus @default(PENDING)
  submittedBy String
  approvedBy  String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ============ RANKING ============
model RankingEntry {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  year      Int
  points    Float
  bestDates Json     // Array of { tournamentId, points, position }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, year])
}

// ============ PUSH NOTIFICATIONS ============
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  keys      Json     // { p256dh, auth }
  userId    String?
  createdAt DateTime @default(now())
}

/// Avisos internos en el sitio (panel Prensa). Distinto de notificaciones Web Push.
model SiteNotification {
  id               String   @id @default(cuid())
  title            String
  body             String?
  linkUrl          String?
  createdByUserId  String?
  createdAt        DateTime @default(now())
  reads            SiteNotificationRead[]

  @@index([createdAt(sort: Desc)])
}

model SiteNotificationRead {
  id             String    @id @default(cuid())
  userId         String
  notificationId String
  readAt         DateTime  @default(now())
  dismissedAt    DateTime?
  notification   SiteNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@index([userId, dismissedAt])
}

/// Empadronamiento web menores/juveniles (temporada anual).
model YouthEnrollment {
  id                  String   @id @default(cuid())
  seasonYear          Int
  dniHash             String

  responsibleName     String
  responsiblePhoneEnc String

  lastName            String
  firstName           String
  gender              String
  birthDate           DateTime @db.Date
  ageDec31            Int
  category            String
  dniEnc              String
  address             String
  department          String
  locality            String
  phoneEnc            String
  emailEnc            String
  clubName            String
  clubCode            String?
  clubId              String?
  club                Club?    @relation(fields: [clubId], references: [id])

  school              String?
  hasHandicap         Boolean
  matricula           String?
  professors          Json?
  professorOther      String?

  tutor1Name          String
  tutor1DniEnc        String
  tutor1PhoneEnc      String
  tutor1EmailEnc      String

  tutor2Name          String?
  tutor2DniEnc        String?
  tutor2EmailEnc      String?

  healthData          Json

  comments            String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([seasonYear, dniHash])
  @@index([seasonYear])
  @@index([clubId])
}

/// Encabezado / torneo activo para inscripciones menores (editable por admin).
model YouthTournamentSignupConfig {
  id          String   @id @default(cuid())
  isActive    Boolean  @default(false)
  title       String
  dateLabel   String
  extraLine   String?
  venue       String
  fecha       String
  sede        String
  modalidad   String
  tournamentKey String @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Inscripción de jugador empadronado a torneo menores activo.
model YouthTournamentRegistration {
  id                    String   @id @default(cuid())
  tournamentKey         String
  enrollmentId          String
  dniHash               String
  responsibleName       String
  responsiblePhoneEnc   String
  responsibleEmailEnc   String
  clubName              String
  clubOther             String?
  clubId                String?
  club                  Club?    @relation(fields: [clubId], references: [id])
  lastName              String
  firstName             String
  gender                String
  hasHandicap           Boolean
  matricula             String?
  birthDate             DateTime @db.Date
  ageAtSignup           Int
  category              String
  playsPrejuvenilesAlso Boolean  @default(false)
  isPrincipiante        Boolean  @default(false)
  dietaryRestriction    Boolean
  dietaryFoods          String?
  comments              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tournamentKey, dniHash])
  @@index([tournamentKey])
  @@index([clubId])
}
